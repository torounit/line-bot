{
  "name": "line-bot",
  "type": "module",
  "scripts": {
    "dev": "wrangler dev",
    "deploy": "wrangler deploy --minify",
    "cf-typegen": "wrangler types --env-interface CloudflareBindings",
    "typecheck": "tsc --noEmit && tsc --noEmit -p test/tsconfig.json",
    "format": "biome format --write .",
    "lint": "biome lint .",
    "check": "biome check --write .",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "hono": "^4.12.30"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.5.4",
    "@cloudflare/vitest-pool-workers": "^0.18.5",
    "@types/node": "^26.1.1",
    "typescript": "^7.0.2",
    "vitest": "^4.1.10",
    "wrangler": "^4.110.0"
  },
  "devEngines": {
    "packageManager": {
      "name": "pnpm",
      "version": "11.14.0",
      "onFail": "download"
    }
  }
}
