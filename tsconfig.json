{
  "compilerOptions": {
    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "strict": true,
    "skipLibCheck": true,
    "lib": ["ESNext"],
    "jsx": "react-jsx",
    "jsxImportSource": "hono/jsx"
  },
  // test/ は @cloudflare/vitest-pool-workers/types が必要なため test/tsconfig.json で個別に型チェックする
  "exclude": ["test"]
}
